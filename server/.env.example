# ─── Server ───
PORT=5000
NODE_ENV=development
# For production: set to your Vercel frontend URL
CLIENT_URL=http://localhost:5173

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Cloudinary (Image Uploads) ───
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── M-Pesa Daraja API ───
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
# For production: use your AWS App Runner URL
MPESA_CALLBACK_URL=https://your-apprunner-url.awsapprunner.com/api/mpesa/callback
# sandbox = Safaricom test | live = real payments
MPESA_ENV=sandbox
